generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  SEED
  SPROUT
  GROWING
  BLOOMING
  WILTING
  DEAD
  COMPLETED
}

enum ProgressType {
  TIME
  REPS
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  passwordHash      String
  username          String           @unique
  name              String?
  avatar            String?
  usernameChangedAt DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tasks         Task[]
  plots         Plot[]
  focusSessions FocusSession[]
  streaks       WateringStreak[]
}

model Plot {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("forest")
  icon      String   @default("leaf")
  order     Int      @default(0)
  gridSnap  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  tasks     Task[]

  @@index([userId, order])
}

model Task {
  id                String         @id @default(cuid())
  userId            String
  title             String
  description       String?
  category          String?
  plotId            String?
  isPot             Boolean        @default(false)
  priority          Int            @default(5)
  status            TaskStatus     @default(SEED)
  parentTaskId      String?
  totalFocusMinutes Int            @default(0)
  progressType      ProgressType   @default(TIME)
  estimatedMinutes  Int?
  targetReps        Int?
  completedReps     Int            @default(0)
  lastWateredAt     DateTime?
  dueDate           DateTime?
  completedAt       DateTime?
  posX              Float?
  posY              Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id])
  plot              Plot?          @relation(fields: [plotId], references: [id])
  subtasks          Task[]         @relation("SubTasks")
  parentTask        Task?          @relation("SubTasks", fields: [parentTaskId], references: [id])
  focusSessions     FocusSession[]
}

model FocusSession {
  id              String   @id @default(cuid())
  userId          String
  taskId          String
  durationMinutes Int
  completedAt     DateTime @default(now())
  notes           String?
  user            User     @relation(fields: [userId], references: [id])
  task            Task     @relation(fields: [taskId], references: [id])
}

model WateringStreak {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastWateredDate DateTime?
  user            User      @relation(fields: [userId], references: [id])
}
